SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFoZWNydWZteHRyaXlpdmFhZW5nIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2OTU2NjU3OCwiZXhwIjoyMDg1MTQyNTc4fQ.Pd3Ek4tnnEiBrRdxbLCUKsflraRnOp-arY_Cy5Uapyk

# Supabase Storage Configuration
SUPABASE_STORAGE_BUCKET=cdl-files
SUPABASE_STORAGE_URL=https://ahecrufmxtriyivaaeng.supabase.co/storage/v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRY=3600000
PASSWORD_RESET_URL=http://localhost:4200/reset-password

# Email Configuration (SendGrid - RECOMMENDED)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=noreply@cdltickets.com
FROM_NAME=CDL Ticket Management

# SendGrid Template IDs (optional - for custom templates)
SENDGRID_WELCOME_TEMPLATE_ID=d-xxxxxxxxxxxxx
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-xxxxxxxxxxxxx
SENDGRID_NOTIFICATION_TEMPLATE_ID=d-xxxxxxxxxxxxx

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar API Configuration (OPTIONAL)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CALENDAR_ENABLED=false

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/ws

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_DIR=uploads

# Notification Configuration
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_RETRY_ATTEMPTS=3

# Court Date Reminder Configuration
REMINDER_INTERVALS=7d,1d,2h
REMINDER_CHECK_INTERVAL=3600000

# Video Call Configuration
VIDEO_CALL_BASE_URL=https://meet.example.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# CORS
CORS_ORIGIN=http://localhost:4200

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all "your-*" placeholders with actual values
# 3. Generate secure secrets for JWT_SECRET and JWT_REFRESH_SECRET (min 32 chars)
# 4. Configure third-party services (SendGrid, Twilio, Supabase, Google Calendar)
# 5. Run migrations: npm run migrate
# 6. Start server: npm run dev
#
# See SETUP.md for detailed configuration instructions

