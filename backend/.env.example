# ============================================
# ENVIRONMENT VARIABLES
# CDL Ticket Management Backend
# ============================================

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/cdl_tickets

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Storage Configuration
SUPABASE_STORAGE_BUCKET=cdl-files
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Password Reset Configuration
PASSWORD_RESET_TOKEN_EXPIRY=3600000
PASSWORD_RESET_URL=http://localhost:4200/reset-password

# Email Configuration (SendGrid - RECOMMENDED)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
FROM_EMAIL=noreply@cdltickets.com
FROM_NAME=CDL Ticket Management

# SendGrid Template IDs (optional - for custom templates)
SENDGRID_WELCOME_TEMPLATE_ID=d-xxxxxxxxxxxxx
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-xxxxxxxxxxxxx
SENDGRID_NOTIFICATION_TEMPLATE_ID=d-xxxxxxxxxxxxx

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar API Configuration (OPTIONAL)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CALENDAR_ENABLED=false

# WebSocket Configuration
WS_PORT=3001
WS_PATH=/ws

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_DIR=uploads

# Notification Configuration
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_RETRY_ATTEMPTS=3

# Court Date Reminder Configuration
REMINDER_INTERVALS=7d,1d,2h
REMINDER_CHECK_INTERVAL=3600000

# Video Call Configuration
VIDEO_CALL_BASE_URL=https://meet.example.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# CORS
CORS_ORIGIN=http://localhost:4200

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production

# ============================================
# ENHANCED FEATURES - NEW CONFIGURATION
# ============================================

# Redis Configuration (Optional - For Caching & Performance)
# Recommended for production to cache analytics and assignment data
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
REDIS_TTL=3600

# OCR Service Configuration
# Options: 'tesseract' (local, free) or 'google-vision' (cloud, paid)
OCR_SERVICE=tesseract

# Google Vision API (Required only if OCR_SERVICE=google-vision)
GOOGLE_VISION_API_KEY=your-google-vision-api-key-here
GOOGLE_VISION_PROJECT_ID=your-gcp-project-id

# Smart Assignment Configuration
ASSIGNMENT_ALGORITHM=smart
ASSIGNMENT_SCORING_WEIGHTS=workload:0.4,expertise:0.3,performance:0.2,availability:0.1

# Analytics Configuration
ANALYTICS_CACHE_ENABLED=true
ANALYTICS_CACHE_TTL=1800

# SLA Configuration (in hours)
SLA_RESPONSE_TIME=24
SLA_RESOLUTION_TIME=168
SLA_WARNING_THRESHOLD=0.8

# Workflow Configuration
WORKFLOW_AUTOMATION_ENABLED=true
WORKFLOW_CHECK_INTERVAL=60000

# Message Template Configuration
TEMPLATES_CACHE_ENABLED=true
TEMPLATES_CACHE_TTL=3600

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all "your-*" placeholders with actual values
# 3. Generate secure secrets for JWT_SECRET and JWT_REFRESH_SECRET (min 32 chars)
# 4. Configure third-party services (SendGrid, Twilio, Supabase, Google Calendar)
# 5. OPTIONAL: Install Redis for caching (brew install redis / apt-get install redis)
# 6. OPTIONAL: Install Tesseract for OCR (brew install tesseract / apt-get install tesseract-ocr)
# 7. Run migrations: npm run migrate
# 8. Start server: npm run dev
#
# See SETUP.md and ENHANCED_FEATURES.md for detailed configuration instructions

# ============================================
# REDIS SETUP (OPTIONAL BUT RECOMMENDED)
# ============================================
# macOS: brew install redis && brew services start redis
# Ubuntu: sudo apt-get install redis-server && sudo systemctl start redis
# Docker: docker run -d -p 6379:6379 redis:alpine
# Then set: REDIS_URL=redis://localhost:6379 and REDIS_ENABLED=true

# ============================================
# OCR SETUP (OPTIONAL)
# ============================================
# For Tesseract (Free, Local):
#   macOS: brew install tesseract
#   Ubuntu: sudo apt-get install tesseract-ocr
#   Set: OCR_SERVICE=tesseract
#
# For Google Vision (Paid, Cloud):
#   1. Enable Cloud Vision API in Google Cloud Console
#   2. Create API key or service account
#   3. Set: OCR_SERVICE=google-vision
#   4. Set: GOOGLE_VISION_API_KEY=your-key-here