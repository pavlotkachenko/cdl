:80 {
    root * /srv
    file_server
    try_files {path} /index.html

    @static {
        path *.js *.css *.ico *.svg *.png *.jpg *.jpeg *.gif *.woff *.woff2 *.ttf *.webp *.webmanifest
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"
}
