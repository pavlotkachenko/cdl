{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "ng cache clean",
    "start": "ng serve",
    "prebuild": "ng cache clean",
    "build": "ng build",
    "clean": "ng cache clean && rm -rf dist",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "cypress run --spec 'cypress/e2e/auth/**/*.cy.ts'",
    "storybook": "ng run frontend:storybook",
    "build-storybook": "ng run frontend:build-storybook",
    "dev": "npx concurrently --names FE,SB --prefix-colors blue,magenta \"ng serve\" \"ng run frontend:storybook\"",
    "dev:all": "npx concurrently --names BE,FE,SB --prefix-colors green,blue,magenta \"cd ../backend && npm run dev\" \"ng serve\" \"ng run frontend:storybook\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.1.3",
    "@angular/cdk": "^21.1.4",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.1",
    "@angular/material": "^21.1.4",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.3",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.3",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/addon-toolbars": "^9.0.8",
    "@storybook/addon-viewport": "^9.0.8",
    "@stripe/stripe-js": "^8.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.5",
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular-devkit/core": "^21.1.0",
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/angular": "^10.2.19",
    "@types/chart.js": "^2.9.41",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^25.3.0",
    "autoprefixer": "^10.4.23",
    "axe-core": "^4.11.1",
    "cypress": "^15.11.0",
    "cypress-axe": "^1.7.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "storybook": "^10.2.19",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
