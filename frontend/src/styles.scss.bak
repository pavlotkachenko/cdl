// ============================================
// Main Styles
// ============================================
// CDL Ticket Management - Integrated Design System
// Location: frontend/src/styles.scss

// ============================================
// IMPORTS
// ============================================

// Fonts
@import ./'assets/styles/fonts';

// Variables & Mixins
@import './assets/styles/variables';
@import './assets/styles/mixins/responsive';

// Angular Material Theme
@import './assets/styles/theme';

// Base Styles
@import './assets/styles/general';

// Component Styles
@import './assets/styles/components/input';
@import './assets/styles/components/button';
@import './assets/styles/components/card';
@import './assets/styles/components/table';
@import './assets/styles/components/link';

// Material Component Overrides
@import './assets/styles/material-theme/button';
@import './assets/styles/material-theme/toggle-buttons';
@import './assets/styles/material-theme/select';
@import './assets/styles/material-theme/icon';

// Icons
@import './assets/styles/icons';

// ============================================
// GLOBAL RESETS
// ============================================

*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
  
  @include reduced-motion {
    scroll-behavior: auto;
  }
}

body {
  font-family: $font-primary;
  font-size: $body-size;
  font-weight: $font-regular;
  line-height: $line-height-normal;
  color: $primary-black;
  background-color: #ffffff;
  overflow-x: hidden;
  
  &.no-scroll {
    overflow: hidden;
  }
}

// ============================================
// UTILITY CLASSES
// ============================================

// Container
.container {
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 $container-padding-desktop;
  
  @include mobileAndTablet {
    padding: 0 $container-padding-mobile;
  }
}

.container-fluid {
  width: 100%;
  padding: 0 $container-padding-desktop;
  
  @include mobileAndTablet {
    padding: 0 $container-padding-mobile;
  }
}

// Spacing Utilities
.mt-auto { margin-top: auto !important; }
.mb-auto { margin-bottom: auto !important; }
.ml-auto { margin-left: auto !important; }
.mr-auto { margin-right: auto !important; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

// Display Utilities
.d-none { display: none !important; }
.d-block { display: block !important; }
.d-flex { display: flex !important; }
.d-grid { display: grid !important; }

// Flex Utilities
.flex-row { flex-direction: row; }
.flex-column { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.align-center { align-items: center; }
.align-start { align-items: flex-start; }
.align-end { align-items: flex-end; }

// Gap Utilities
.gap-sm { gap: $spacing-sm; }
.gap-md { gap: $spacing-md; }
.gap-lg { gap: $spacing-lg; }
.gap-xl { gap: $spacing-xl; }

// Visibility
@include mobile {
  .hide-mobile { display: none !important; }
}

@include desktop {
  .hide-desktop { display: none !important; }
}

.show-mobile {
  display: none;
  @include mobile { display: block; }
}

.show-desktop {
  display: none;
  @include desktop { display: block; }
}

// ============================================
// ACCESSIBILITY
// ============================================

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

.skip-to-content {
  position: absolute;
  top: -40px;
  left: 0;
  background: $accent-green;
  color: white;
  padding: 8px;
  text-decoration: none;
  border-radius: 0 0 $border-radius-md 0;
  z-index: $z-tooltip;
  
  &:focus {
    top: 0;
  }
}

// Focus visible
*:focus-visible {
  outline: 2px solid $accent-green;
  outline-offset: 2px;
}

// ============================================
// ANIMATIONS
// ============================================

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideInUp {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideInDown {
  from {
    transform: translateY(-20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.fade-in {
  animation: fadeIn $transition-base;
}

.slide-in-up {
  animation: slideInUp $transition-slow;
}

.slide-in-down {
  animation: slideInDown $transition-slow;
}

.spin {
  animation: spin 1s linear infinite;
}

// Reduce motion for accessibility
@include reduced-motion {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

// ============================================
// LOADING STATES
// ============================================

.loading {
  position: relative;
  pointer-events: none;
  opacity: 0.6;
  
  &::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 24px;
    margin: -12px 0 0 -12px;
    border: 2px solid $accent-green;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }
}

// ============================================
// SCROLLBAR STYLING
// ============================================

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: $light-grey;
}

::-webkit-scrollbar-thumb {
  background: $dark-grey;
  border-radius: $border-radius-full;
  
  &:hover {
    background: darken($dark-grey, 10%);
  }
}

// ============================================
// SELECTION
// ============================================

::selection {
  background-color: rgba($accent-green, 0.2);
  color: $title-black;
}

::-moz-selection {
  background-color: rgba($accent-green, 0.2);
  color: $title-black;
}
