<!-- Layout Component Template - Complete Driver Layout -->
<!-- Location: frontend/src/app/core/layout/layout.component.html -->

<div class="app-layout">

  <!-- Header -->
  <mat-toolbar class="app-header" color="primary">
    <button mat-icon-button (click)="toggleSidebar()" class="menu-toggle">
      <mat-icon>menu</mat-icon>
    </button>

    <div class="header-left">
      <img src="assets/logo.png" alt="CDL Ticket Management" class="logo" *ngIf="!isMobile">
      <h1 class="app-title">CDL Ticket Management</h1>
    </div>

    <span class="spacer"></span>

    <div class="header-right">
      <!-- Search (Optional) -->
      <button mat-icon-button class="header-action" matTooltip="Search">
        <mat-icon>search</mat-icon>
      </button>

      <!-- Notification Bell -->
      <app-notification-bell></app-notification-bell>

      <!-- User Menu -->
      <button mat-button [matMenuTriggerFor]="userMenu" class="user-button">
        <mat-icon class="user-avatar">account_circle</mat-icon>
        <span class="user-name" *ngIf="!isMobile">{{ userName }}</span>
        <mat-icon class="dropdown-icon">arrow_drop_down</mat-icon>
      </button>
      <mat-menu #userMenu="matMenu" xPosition="before">
        <div class="user-menu-header">
          <div class="user-info">
            <mat-icon class="user-avatar-large">account_circle</mat-icon>
            <div>
              <div class="user-menu-name">{{ userName }}</div>
              <div class="user-menu-email">{{ userEmail }}</div>
            </div>
          </div>
        </div>
        <mat-divider></mat-divider>
        <button mat-menu-item routerLink="/driver/profile">
          <mat-icon>person</mat-icon>
          <span>My Profile</span>
        </button>
        <button mat-menu-item routerLink="/driver/settings">
          <mat-icon>settings</mat-icon>
          <span>Settings</span>
        </button>
        <button mat-menu-item routerLink="/driver/help">
          <mat-icon>help</mat-icon>
          <span>Help & Support</span>
        </button>
        <mat-divider></mat-divider>
        <button mat-menu-item (click)="logout()">
          <mat-icon>logout</mat-icon>
          <span>Logout</span>
        </button>
      </mat-menu>
    </div>
  </mat-toolbar>

  <!-- Sidenav Container -->
  <mat-sidenav-container class="sidenav-container">
    
    <!-- Sidebar -->
    <mat-sidenav 
      #sidenav
      [mode]="sidenavMode"
      [opened]="sidenavOpened"
      [fixedInViewport]="true"
      [fixedTopGap]="64"
      class="app-sidenav">
      <app-sidebar></app-sidebar>
    </mat-sidenav>

    <!-- Main Content Area -->
    <mat-sidenav-content class="main-content">
      <div class="content-wrapper">
        <router-outlet></router-outlet>
      </div>

      <!-- Footer -->
      <footer class="app-footer">
        <div class="footer-content">
          <p>&copy; {{ currentYear }} CDL Ticket Management. All rights reserved.</p>
          <div class="footer-links">
            <a routerLink="/privacy">Privacy Policy</a>
            <span class="separator">•</span>
            <a routerLink="/terms">Terms of Service</a>
            <span class="separator">•</span>
            <a routerLink="/contact">Contact Us</a>
          </div>
        </div>
      </footer>
    </mat-sidenav-content>

  </mat-sidenav-container>

</div>
